# Visa provider credentials
VFS_EMAIL=your@email.com
VFS_PASSWORD=yourpassword
TLS_EMAIL=your@email.com
TLS_PASSWORD=yourpassword
BLS_EMAIL=your@email.com
BLS_PASSWORD=yourpassword
CAPAGO_EMAIL=your@email.com
CAPAGO_PASSWORD=yourpassword

# Telegram (primary alert channel)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321

# ntfy.sh push notifications (free)
NTFY_TOPIC=visa-checker-yourUniqueTopicName

# Email (optional)
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_TO=you@gmail.com

# Twilio SMS (optional)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+441234567890
TWILIO_TO=+441234567890

# CAPTCHA solving
# Default (free): audio_recaptcha — no key needed, just install playwright-recaptcha + ffmpeg
#
# For hCaptcha accessibility bypass (free — covers TLScontact):
#   1. Register at https://www.hcaptcha.com/accessibility
#   2. Click the emailed link to get your token
#   3. Paste it below
HCAPTCHA_ACCESSIBILITY_TOKEN=

# For paid solvers (2captcha / anticaptcha):
CAPTCHA_API_KEY=your_2captcha_or_anticaptcha_key

# Proxy (optional)
PROXY_ENDPOINT=http://user:pass@proxy.brightdata.com:22225

# Discord (optional)
# Create webhook: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefghij...

# WeChat personal push via WxPusher (free, no business account)
# Setup: https://wxpusher.zjiecode.com → create app → scan QR in WeChat → copy APP_TOKEN + UID
WXPUSHER_APP_TOKEN=AT_xxxxxxxxxxxxxxxx
WXPUSHER_UID=UID_xxxxxxxxxxxxxxxx

# WeChat Work (WeCom) group bot (free with WeCom account)
# Setup: WeCom group → right-click → Add Group Robot → Create → copy URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Config path override (optional)
VISA_CHECKER_CONFIG=config/config.yaml
