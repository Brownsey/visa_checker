# Visa provider credentials
VFS_EMAIL=your@email.com
VFS_PASSWORD=yourpassword
TLS_EMAIL=your@email.com
TLS_PASSWORD=yourpassword
BLS_EMAIL=your@email.com
BLS_PASSWORD=yourpassword
CAPAGO_EMAIL=your@email.com
CAPAGO_PASSWORD=yourpassword

# Telegram (primary alert channel)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321

# ntfy.sh push notifications (free)
NTFY_TOPIC=visa-checker-yourUniqueTopicName

# Email (optional)
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_TO=you@gmail.com

# Twilio SMS (optional)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+441234567890
TWILIO_TO=+441234567890

# CAPTCHA solving (optional, needed for automated login)
CAPTCHA_API_KEY=your_2captcha_or_anticaptcha_key

# Proxy (optional)
PROXY_ENDPOINT=http://user:pass@proxy.brightdata.com:22225

# Config path override (optional)
VISA_CHECKER_CONFIG=config/config.yaml
